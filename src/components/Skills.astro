---
const skillGroups = [
  {
    title: 'Frontend',
    skills: ['React JS', 'Next.js', 'Vue.js', 'Astro', 'Tailwind CSS', 'TypeScript', 'JavaScript']
  },
  {
    title: 'Backend',
    skills: ['NestJS', 'Express.js', 'Node.js', 'Go', 'Prisma ORM']
  },
  {
    title: 'Bases de Datos & DevOps',
    skills: ['PostgreSQL', 'MySQL', 'MongoDB', 'Redis', 'Docker', 'Linux', 'Git']
  }
];
---

<section id="skills" class="py-24 scroll-mt-20">
  <div class="container mx-auto px-6 max-w-5xl">
    <h2 class="text-3xl md:text-4xl font-bold mb-16 flex items-center justify-center gap-4 reveal">
      <span class="text-(--accent-500)">04.</span> Habilidades Tecnicas
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {skillGroups.map((group, groupIndex) => (
        <div class="reveal-up" style={`transition-delay: ${groupIndex * 0.1}s`}>
          <h3 class="text-xl font-bold mb-8 text-slate-800 dark:text-slate-200 border-b border-teal-500/25 pb-2">
            {group.title}
          </h3>
          <div class="grid grid-cols-2 gap-4">
            {group.skills.map(skill => (
              <div class="flex items-center gap-2 p-3 rounded-xl bg-(--surface-1) border border-(--surface-2) hover:border-(--accent-500) hover:shadow-lg hover:shadow-cyan-900/10 transition-all group overflow-hidden relative">
                <div class="absolute inset-0 bg-(--accent-soft) translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
                <!-- Placeholder Icon -->
                <div class="w-2 h-2 rounded-full bg-(--accent-500)"></div>
                <span class="text-sm font-medium relative z-10">{skill}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
