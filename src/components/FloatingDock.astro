---
import { personal } from "../data/personal";
import ThemeToggle from "./ThemeToggle.astro";

const navItems = [
  { name: "Sobre mi", href: "#about", icon: "user" },
  { name: "Experiencia", href: "#experience", icon: "briefcase" },
  { name: "Proyectos", href: "#projects", icon: "folder" },
  { name: "Habilidades", href: "#skills", icon: "spark" },
  { name: "Contacto", href: "#contact", icon: "mail" },
];

const firstName = personal.name.split(" ")[0] || "Jose";
---

<nav class="dock-wrap" aria-label="Navegacion principal">
  <div class="dock-shell">
    <a href="#hero" class="dock-item dock-brand" aria-label={`Inicio de ${firstName}`}>
      <span class="dock-tip">{firstName}</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 10.5 12 3l9 7.5"></path>
        <path stroke-linecap="round" stroke-linejoin="round" d="M5.5 9.5V20h13V9.5"></path>
      </svg>
    </a>

    {
      navItems.map((item) => (
        <a href={item.href} class="dock-item" aria-label={item.name}>
          <span class="dock-tip">{item.name}</span>
          {item.icon === "user" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="8" r="4"></circle>
              <path stroke-linecap="round" d="M4 20c2.3-3.3 5-5 8-5s5.7 1.7 8 5"></path>
            </svg>
          )}
          {item.icon === "briefcase" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="3" y="7" width="18" height="13" rx="2"></rect>
              <path stroke-linecap="round" d="M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path>
            </svg>
          )}
          {item.icon === "folder" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 7h6l2 2h10v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"></path>
            </svg>
          )}
          {item.icon === "spark" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" d="m12 3 1.8 4.8L19 9.6l-4.4 2.5L13 17l-1.6-4.9L7 9.6l5.2-1.8L12 3z"></path>
            </svg>
          )}
          {item.icon === "mail" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path stroke-linecap="round" d="m4 7 8 6 8-6"></path>
            </svg>
          )}
        </a>
      ))
    }

    <div class="dock-item dock-theme-tone" aria-label="Cambiar tema">
      <span class="dock-tip">Tema</span>
      <ThemeToggle inDock={true} />
    </div>
  </div>
</nav>
